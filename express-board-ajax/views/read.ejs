<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>게시글 조회</title>
    <link rel='stylesheet' href='/stylesheets/style.css'/>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: Arial, sans-serif;
        }
        table {
            margin: 0 auto;
        }
        h1, h2, h3 {
            text-align: center;
        }
    </style>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
</head>
<body>
<div class="container">
    <h1><%= title %></h1>
    <% if (typeof username !== 'undefined') { %>
    <a href="/logout" id="logout-link">로그아웃</a>
    <% } %>
    <table border="1">
        <tr>
            <td>번호</td>
            <td><%= row.postid %></td>
        </tr>
        <tr>
            <td>제목</td>
            <td><%= row.title %></td>
        </tr>
        <tr>
            <td>작성자</td>
            <td><%= row.author %></td>
        </tr>
        <tr>
            <td>작성일자</td>
            <td><%= row.regdate.toLocaleString('en-US', { timeZone: 'Asia/Seoul' }) %></td>
        </tr>
        <tr>
            <td>내용</td>
            <td><%= row.body %></td>
        </tr>
        <tr>
            <td>좋아요</td>
            <td>
                <span id="like-count"><%= row.likes %></span>
                <button id="like-button"><%= liked ? '좋아요 취소' : '좋아요' %></button>
            </td>
        </tr>
        <% if (row.author === username) { %>
        <tr>
            <td colspan="2">
                <button id="delete-post-button">글 삭제</button>
                <a href="/list">목록</a>
            </td>
        </tr>
        <% } else { %>
        <tr>
            <td colspan="2">
                <a href="/list">목록</a>
            </td>
        </tr>
        <% } %>
    </table>

    <h2>댓글</h2>
    <table border="1">
        <% replies.forEach(function(reply) { %>
        <tr>
            <td><%= reply.commentwriter %></td>
            <td><%= reply.commentcontent %></td>
            <td><%= reply.commentdate.toLocaleString('en-US', { timeZone: 'Asia/Seoul' }) %></td>
            <td>
                <% if (reply.commentwriter === username) { %>
                <button class="delete-reply-button" data-commentid="<%= reply.commentid %>">댓글 삭제</button>
                <% } %>
            </td>
        </tr>
        <% }); %>
    </table>

    <h3>댓글 작성</h3>
    <form id="reply-form">
        <input type="hidden" name="postid" value="<%= row.postid %>">
        <table border="1">
            <tr>
                <td>작성자</td>
                <td><input type="text" name="commentwriter" value="<%= username %>" readonly/></td>
            </tr>
            <tr>
                <td>내용</td>
                <td><textarea name="commentcontent" cols="30" rows="10" required></textarea></td>
            </tr>
            <tr>
                <td colspan="2">
                    <button type="submit">댓글 작성</button>
                </td>
            </tr>
        </table>
    </form>
</div>

<script>
    function likePost() {
        const postid = $('input[name="postid"]').val();

        $.ajax({
            type: 'POST',
            url: '/like',
            contentType: 'application/json',
            data: JSON.stringify({ postid: postid }),
            success: function(response) {
                if (response.success) {
                    $('#like-count').text(response.likes);
                    if (response.liked) {
                        $('#like-button').text('좋아요 취소');
                    } else {
                        $('#like-button').text('좋아요');
                    }
                } else {
                    alert(response.message);
                }
            },
            error: function(error) {
                console.error('좋아요 처리 오류:', error);
                alert('좋아요 처리 오류');
            }
        });
    }

    function deletePost() {
        const postid = $('input[name="postid"]').val();

        $.ajax({
            type: 'POST',
            url: '/delete',
            contentType: 'application/json',
            data: JSON.stringify({ postid: postid }),
            success: function() {
                window.location.href = '/list';
            },
            error: function(error) {
                console.error('게시물 삭제 오류:', error);
                alert('게시물 삭제 오류');
            }
        });
    }

    function deleteReply(commentid) {
        $.ajax({
            type: 'POST',
            url: '/deletereply',
            contentType: 'application/json',
            data: JSON.stringify({ commentid: commentid }),
            success: function() {
                location.reload();
            },
            error: function(error) {
                console.error('댓글 삭제 오류:', error);
                alert('댓글 삭제 오류');
            }
        });
    }

    $('#like-button').on('click', likePost);
    $('#delete-post-button').on('click', deletePost);
    $('.delete-reply-button').on('click', function() {
        const commentid = $(this).data('commentid');
        deleteReply(commentid);
    });

    $('#reply-form').on('submit', function(evt) {
        evt.preventDefault();
        
        const formData = $(this).serialize();

        $.ajax({
            type: 'POST',
            url: '/reply',
            data: formData,
            success: function() {
                location.reload();
            },
            error: function(error) {
                console.error('댓글 작성 오류:', error);
                alert('댓글 작성 오류');
            }
        });
    });

    $('#logout-link').on('click', function(evt) {
        evt.preventDefault();
        $.ajax({
            type: 'GET',
            url: '/logout',
            success: function() {
                window.location.href = '/';
            },
            error: function() {
                alert('로그아웃 실패');
            }
        });
    });
</script>
</body>
</html>

